# Models (VERY IMPORTANT)
models/
*.gguf

# Temporary downloads
*.tmp
*.part

# Checksums (optional: keep JSON, ignore TXT if needed)
# checksums/SHA256SUMS.txt

# Python cache
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log

# Local env
.env